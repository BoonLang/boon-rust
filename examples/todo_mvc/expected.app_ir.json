{
  "state_cells": [],
  "list_states": [
    {
      "path": "todos",
      "initial_entries": [
        {
          "text": "Buy groceries",
          "mark": false
        },
        {
          "text": "Clean room",
          "mark": false
        }
      ]
    }
  ],
  "static_records": [
    {
      "path": "view",
      "fields": [
        {
          "key": "title_line",
          "value": {
            "kind": "text",
            "value": "todos"
          }
        },
        {
          "key": "entry_hint",
          "value": {
            "kind": "text",
            "value": "What needs to be done?"
          }
        },
        {
          "key": "count_suffix",
          "value": {
            "kind": "text",
            "value": "items left"
          }
        },
        {
          "key": "selectors",
          "value": {
            "kind": "record",
            "fields": [
              {
                "key": "filter_all",
                "value": {
                  "kind": "record",
                  "fields": [
                    {
                      "key": "label",
                      "value": {
                        "kind": "text",
                        "value": "All"
                      }
                    },
                    {
                      "key": "visibility",
                      "value": {
                        "kind": "tag",
                        "value": "All"
                      }
                    }
                  ]
                }
              },
              {
                "key": "filter_active",
                "value": {
                  "kind": "record",
                  "fields": [
                    {
                      "key": "label",
                      "value": {
                        "kind": "text",
                        "value": "Active"
                      }
                    },
                    {
                      "key": "visibility",
                      "value": {
                        "kind": "tag",
                        "value": "Unmarked"
                      }
                    }
                  ]
                }
              },
              {
                "key": "filter_completed",
                "value": {
                  "kind": "record",
                  "fields": [
                    {
                      "key": "label",
                      "value": {
                        "kind": "text",
                        "value": "Completed"
                      }
                    },
                    {
                      "key": "visibility",
                      "value": {
                        "kind": "tag",
                        "value": "Marked"
                      }
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "key": "actions",
          "value": {
            "kind": "record",
            "fields": [
              {
                "key": "mass_mark",
                "value": {
                  "kind": "record",
                  "fields": []
                }
              },
              {
                "key": "remove_marked",
                "value": {
                  "kind": "record",
                  "fields": [
                    {
                      "key": "label",
                      "value": {
                        "kind": "text",
                        "value": "Clear completed"
                      }
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "key": "auxiliary",
          "value": {
            "kind": "record",
            "fields": [
              {
                "key": "hint",
                "value": {
                  "kind": "text",
                  "value": "Double-click to edit an item"
                }
              },
              {
                "key": "author",
                "value": {
                  "kind": "text",
                  "value": "Created by Boon"
                }
              },
              {
                "key": "note",
                "value": {
                  "kind": "text",
                  "value": "Part of the classic app examples"
                }
              }
            ]
          }
        }
      ]
    }
  ],
  "event_handlers": [
    {
      "source_path": "store.sources.new_todo_input.event.key_down.key",
      "when": {
        "kind": "source_tag_equals",
        "path": "store.sources.new_todo_input.event.key_down.key",
        "tag": "Enter"
      },
      "effects": [
        {
          "kind": "list_append_text",
          "list_path": "todos",
          "text_state_path": "store.sources.new_todo_input.text",
          "trim": true,
          "skip_empty": true
        },
        {
          "kind": "clear_text",
          "text_state_path": "store.sources.new_todo_input.text"
        }
      ]
    },
    {
      "source_path": "todos[*].sources.remove_button.event.press",
      "when": null,
      "effects": [
        {
          "kind": "list_remove_owner",
          "list_path": "todos"
        }
      ]
    },
    {
      "source_path": "store.sources.clear_completed_button.event.press",
      "when": null,
      "effects": [
        {
          "kind": "list_remove_marked",
          "list_path": "todos"
        }
      ]
    },
    {
      "source_path": "store.sources.filter_all.event.press",
      "when": null,
      "effects": [
        {
          "kind": "set_tag_state",
          "state_path": "view_selector",
          "value": "filter_all"
        }
      ]
    },
    {
      "source_path": "store.sources.filter_active.event.press",
      "when": null,
      "effects": [
        {
          "kind": "set_tag_state",
          "state_path": "view_selector",
          "value": "filter_active"
        }
      ]
    },
    {
      "source_path": "store.sources.filter_completed.event.press",
      "when": null,
      "effects": [
        {
          "kind": "set_tag_state",
          "state_path": "view_selector",
          "value": "filter_completed"
        }
      ]
    },
    {
      "source_path": "todos[*].sources.checkbox.event.click",
      "when": null,
      "effects": [
        {
          "kind": "list_toggle_owner_mark",
          "list_path": "todos"
        }
      ]
    },
    {
      "source_path": "store.sources.toggle_all_checkbox.event.click",
      "when": null,
      "effects": [
        {
          "kind": "list_toggle_all_marks",
          "list_path": "todos"
        }
      ]
    }
  ],
  "render_tree": {
    "id": "root_0",
    "kind": "root",
    "children": [
      {
        "id": "panel_12",
        "kind": "panel",
        "children": [
          {
            "id": "text_input_1",
            "kind": "text_input",
            "source_path": "store.sources.new_todo_input"
          },
          {
            "id": "checkbox_2",
            "kind": "checkbox",
            "source_path": "store.sources.toggle_all_checkbox"
          },
          {
            "id": "button_3",
            "kind": "button",
            "source_path": "store.sources.clear_completed_button"
          },
          {
            "id": "button_4",
            "kind": "button",
            "source_path": "store.sources.filter_all"
          },
          {
            "id": "button_5",
            "kind": "button",
            "source_path": "store.sources.filter_active"
          },
          {
            "id": "button_6",
            "kind": "button",
            "source_path": "store.sources.filter_completed"
          },
          {
            "id": "list_map_7",
            "kind": "list_map",
            "list_path": "todos",
            "children": [
              {
                "id": "panel_11",
                "kind": "panel",
                "children": [
                  {
                    "id": "checkbox_8",
                    "kind": "checkbox",
                    "source_path": "todos[*].sources.checkbox"
                  },
                  {
                    "id": "button_9",
                    "kind": "button",
                    "source_path": "todos[*].sources.remove_button"
                  },
                  {
                    "id": "text_input_10",
                    "kind": "text_input",
                    "source_path": "todos[*].sources.edit_input"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}