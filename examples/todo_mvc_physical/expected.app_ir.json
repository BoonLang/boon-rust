{
  "state_cells": [],
  "list_states": [
    {
      "path": "todos",
      "initial_entries": [
        {
          "text": "Buy groceries",
          "mark": false
        },
        {
          "text": "Clean room",
          "mark": false
        }
      ]
    }
  ],
  "list_views": [
    {
      "list_path": "todos",
      "title_line": "todos",
      "entry_hint": "What needs to be done?",
      "count_suffix": "items left",
      "remove_marked_label": "Clear completed",
      "auxiliary_lines": [
        "Double-click to edit an item",
        "Created by Boon",
        "Part of the classic app examples",
        "physical debug: depth bounds and source bindings matrix"
      ]
    }
  ],
  "event_handlers": [
    {
      "source_path": "store.sources.new_todo_input.event.key_down.key",
      "when": {
        "kind": "source_tag_equals",
        "path": "store.sources.new_todo_input.event.key_down.key",
        "tag": "Enter"
      },
      "effects": [
        {
          "kind": "list_append_text",
          "list_path": "todos",
          "text_state_path": "store.sources.new_todo_input.text",
          "trim": true,
          "skip_empty": true
        },
        {
          "kind": "clear_text",
          "text_state_path": "store.sources.new_todo_input.text"
        }
      ]
    },
    {
      "source_path": "todos[*].sources.remove_button.event.press",
      "when": null,
      "effects": [
        {
          "kind": "list_remove_owner",
          "list_path": "todos"
        }
      ]
    },
    {
      "source_path": "store.sources.clear_completed_button.event.press",
      "when": null,
      "effects": [
        {
          "kind": "list_remove_marked",
          "list_path": "todos"
        }
      ]
    },
    {
      "source_path": "todos[*].sources.checkbox.event.click",
      "when": null,
      "effects": [
        {
          "kind": "list_toggle_owner_mark",
          "list_path": "todos"
        }
      ]
    },
    {
      "source_path": "store.sources.toggle_all_checkbox.event.click",
      "when": null,
      "effects": [
        {
          "kind": "list_toggle_all_marks",
          "list_path": "todos"
        }
      ]
    }
  ],
  "render_tree": {
    "id": "root_0",
    "kind": "root",
    "children": [
      {
        "id": "panel_9",
        "kind": "panel",
        "children": [
          {
            "id": "text_input_1",
            "kind": "text_input",
            "source_path": "store.sources.new_todo_input"
          },
          {
            "id": "checkbox_2",
            "kind": "checkbox",
            "source_path": "store.sources.toggle_all_checkbox"
          },
          {
            "id": "button_3",
            "kind": "button",
            "source_path": "store.sources.clear_completed_button"
          },
          {
            "id": "list_map_4",
            "kind": "list_map",
            "list_path": "todos",
            "children": [
              {
                "id": "panel_8",
                "kind": "panel",
                "children": [
                  {
                    "id": "checkbox_5",
                    "kind": "checkbox",
                    "source_path": "todos[*].sources.checkbox"
                  },
                  {
                    "id": "button_6",
                    "kind": "button",
                    "source_path": "todos[*].sources.remove_button"
                  },
                  {
                    "id": "text_input_7",
                    "kind": "text_input",
                    "source_path": "todos[*].sources.edit_input"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}