  ],
  "event_handlers": [
    {
      "source_path": "store.sources.new_todo_input.event.key_down.key",
      "when": {
        "kind": "source_tag_equals",
        "path": "store.sources.new_todo_input.event.key_down.key",
        "tag": "Enter"
      },
      "effects": [
        {
          "kind": "collection_append_record",
          "collection_path": "todos",
          "fields": [
            {
              "field": "completed",
              "value": {
                "kind": "static",
                "value": {
                  "kind": "bool",
                  "value": false
                }
              }
            },
            {
              "field": "title",
              "value": {
                "kind": "source_text",
                "path": "store.sources.new_todo_input.text",
                "trim": true
              }
            }
          ],
          "skip_if_empty_field": "title"
        },
        {
          "kind": "clear_text",
          "text_state_path": "store.sources.new_todo_input.text"
        }
      ]
    },
    {
      "source_path": "todos[*].sources.remove_button.event.press",
      "when": null,
      "effects": [
        {
          "kind": "collection_remove_current",
          "collection_path": "todos"
        }
      ]
    },
    {
      "source_path": "store.sources.clear_completed_button.event.press",
      "when": null,
      "effects": [
        {
          "kind": "collection_remove_where",
          "collection_path": "todos",
          "predicate": {
            "kind": "field_bool_equals",
            "field": "completed",
            "value": true
          }
        }
      ]
    },
    {
      "source_path": "todos[*].sources.checkbox.event.click",
      "when": null,
      "effects": [
        {
          "kind": "collection_update_owner_field",
          "collection_path": "todos",
          "field": "completed",
          "value": {
            "kind": "not_owner_bool_field",
            "field": "completed"
          }
        }
      ]
    },
    {
      "source_path": "store.sources.toggle_all_checkbox.event.click",
      "when": null,
      "effects": [
        {
          "kind": "collection_update_all_fields",
          "collection_path": "todos",
          "field": "completed",
          "value": {
            "kind": "not_all_bool_field",
            "field": "completed"
          }
        }
      ]
    }
  ],
  "render_tree": {
    "id": "root_0",
    "kind": "root",
    "children": [
      {
        "id": "panel_9",
        "kind": "panel",
        "children": [
          {
            "id": "text_input_1",
            "kind": "text_input",
            "source_path": "store.sources.new_todo_input"
          },
          {
            "id": "checkbox_2",
            "kind": "checkbox",
            "source_path": "store.sources.toggle_all_checkbox"
          },
          {
            "id": "button_3",
            "kind": "button",
            "source_path": "store.sources.clear_completed_button"
          },
          {
            "id": "list_map_4",
            "kind": "list_map",
            "collection_path": "todos",
            "children": [
              {
                "id": "panel_8",
                "kind": "panel",
                "children": [
                  {
                    "id": "checkbox_5",
                    "kind": "checkbox",
                    "source_path": "todos[*].sources.checkbox"
                  },
                  {
                    "id": "button_6",
                    "kind": "button",
                    "source_path": "todos[*].sources.remove_button"
                  },
                  {
                    "id": "text_input_7",
                    "kind": "text_input",
                    "source_path": "todos[*].sources.edit_input"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
