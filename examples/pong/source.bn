store:
    sources:
        tick:
            event:
                frame: SOURCE
        paddle:
            event:
                key_down:
                    key: SOURCE

game:
    title: TEXT { Pong }

kinematics:
    arena:
        width: 1000
        height: 700
    body:
        x: 84
        y: 350
        dx: -12
        dy: 8
        size: 22
    primary_control:
        axis: Vertical
        position: 50
        step: 8
        x: 38
        y: 0
        width: 18
        height: 128
        auto_track: False
    tracked_control:
        axis: Vertical
        position: 50
        step: 8
        x: 944
        y: 0
        width: 18
        height: 128
        auto_track: True

world:
    0 |> HOLD frame {
        store.sources.tick.event.frame |> THEN { frame + 1 }
    }

document:
    Document/new(
        root:
            Element/panel(
                children:
                    LIST {
                        Element/label(element: store.sources.tick)
                        Element/label(element: store.sources.paddle)
                    }
            )
    )
